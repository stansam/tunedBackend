        # 'JWT_TOKEN_LOCATION': ['headers'],
        # 'JWT_HEADER_NAME': 'Authorization',
        # 'JWT_HEADER_TYPE': 'Bearer',
    })
    
    # Create application context
    with app.app_context():
        _db.create_all()
        yield app
        _db.session.remove()
        _db.drop_all()


